# Copy this file to .env and fill in your API keys
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys
# - Google AI (Gemini): https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Event interpretation / task classifier (provider / model; extra slashes stay in the model id) ---
# INTERPRETATION_LLM=groq/llama-3.3-70b-versatile
# TASK_CLASSIFIER_LLM=groq/llama-3.3-70b-versatile
# INTERPRETATION_LLM=groq/llama-3.1-8b-instant
# INTERPRETATION_LLM=openai/gpt-4o-mini
# INTERPRETATION_LLM=anthropic/claude-3-5-haiku-20241022
# INTERPRETATION_LLM=gemini/gemini-2.0-flash
#
# Provider slugs: groq | openai | oai | anthropic | claude | gemini | google
# If the value has no "/", it is treated as an OpenAI-compat model id (legacy; base URL uses key heuristics).
# Override base URL any time: INTERPRETATION_BASE_URL or OPENAI_BASE_URL
#
# Keys (by provider): groq/openai → GROQ_API_KEY, OPENAI_API_KEY, or INTERPRETATION_API_KEY; anthropic → ANTHROPIC_API_KEY; gemini → GEMINI_API_KEY or GOOGLE_API_KEY

GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# IANA timezone for stored local wall-clock times (Insights chat, UI). Example: America/New_York
# USER_TIMEZONE=

# Insights chat: Groq Qwen tool agent (OpenAI-compatible). Override model: INSIGHTS_AGENT_LLM=groq/qwen/qwen3-32b
# INSIGHTS_AGENT_LLM=
